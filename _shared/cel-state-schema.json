{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CEL 迭代状态文件",
  "description": "收敛式工程迭代（CEL）的状态跟踪文件，记录迭代历史和当前状态",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "description": "状态文件格式版本",
      "const": 1
    },
    "task": {
      "type": "object",
      "description": "当前任务信息",
      "properties": {
        "description": {
          "type": "string",
          "description": "任务描述"
        },
        "reference": {
          "type": "string",
          "description": "使用的参考文件名（如：代码开发.md）"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "任务开始时间"
        }
      },
      "required": ["description"]
    },
    "current_iteration": {
      "type": "integer",
      "description": "当前迭代轮次号"
    },
    "current_round_type": {
      "type": "string",
      "enum": ["evaluation", "modification"],
      "description": "当前轮次类型"
    },
    "error_metric": {
      "type": "object",
      "description": "当前误差度量",
      "properties": {
        "formula": {
          "type": "string",
          "description": "误差公式（如：E_dev）"
        },
        "current_value": {
          "type": "number",
          "description": "当前误差值"
        },
        "previous_value": {
          "type": "number",
          "description": "上一轮误差值"
        },
        "dominant_dimension": {
          "type": "string",
          "description": "主导误差维度"
        },
        "dimensions": {
          "type": "array",
          "description": "各误差维度详情",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "number" },
              "weight": { "type": "number" }
            }
          }
        }
      }
    },
    "iterations": {
      "type": "array",
      "description": "迭代历史记录",
      "items": {
        "type": "object",
        "properties": {
          "round": { "type": "integer" },
          "type": { "type": "string", "enum": ["evaluation", "modification"] },
          "action": { "type": "string" },
          "error_before": { "type": "number" },
          "error_after": { "type": "number" },
          "decision": { "type": "string", "enum": ["accept", "rollback", "smaller_retry", "escalate"] },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "oscillation": {
      "type": "object",
      "description": "震荡检测状态",
      "properties": {
        "detected": { "type": "boolean" },
        "pattern": { "type": "string", "description": "震荡模式描述" },
        "consecutive_no_improvement": { "type": "integer", "description": "连续无改进轮次" }
      }
    }
  },
  "required": ["version", "task", "current_iteration"]
}
